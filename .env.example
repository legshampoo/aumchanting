# Copy to .env in this directory (repo root):
#   cp .env.example .env
#
# Production uses the same variable names via GitHub Actions → Lightsail /opt/aumchanting/.env

# API
PORT=8787
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Web — leave unset locally (app defaults to http://localhost:8787)
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_SITE_URL=https://aumchanting.com

# Contact form (Resend) — used by apps/web; required in production via GitHub Actions secrets
# RESEND_API_KEY=re_...
# CONTACT_FROM_EMAIL="OM Chanting <onboarding@resend.dev>"
# CONTACT_TO_EMAIL=you@example.com

# Capacitor — only when pointing the iOS/Android shell at local dev
# CAPACITOR_SERVER_URL=http://192.168.x.x:3000
